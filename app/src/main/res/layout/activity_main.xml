<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Switch
        android:id="@+id/switchSmartDecode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Smart Decode"/>

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter text"/>

    <Button
        android:id="@+id/btnEncode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Encode"/>

    <Button
        android:id="@+id/btnDecode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Decode"/>



    <Button
        android:id="@+id/btnTnetPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="T-NET PANEL"
        android:textStyle="bold"
        android:layout_marginTop="18dp"/>



    <LinearLayout
        android:id="@+id/tnetContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#111111"
        android:padding="14dp"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tvTnetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T-NET SECURE PANEL"
            android:textColor="#00FFAA"
            android:textStyle="bold"
            android:textSize="16sp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnRefreshChannels"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⟳ REFRESH"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnInitiateCommn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INITIATE COMMN"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnPatchIn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PATCH IN"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
                

        </LinearLayout>

        <LinearLayout
            android:id="@+id/channelHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="Sno."
                android:textColor="#00FFAA"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Channel Name"
                android:textColor="#00FFAA"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Inception"
                android:textColor="#00FFAA"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="Action"
                android:textColor="#00FFAA"
                android:textStyle="bold"/>

        </LinearLayout>


        <ScrollView
            android:id="@+id/channelScroll"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            android:background="#1A1A1A">

            <LinearLayout
                android:id="@+id/channelListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">


                <TextView
                    android:id="@+id/tvEmptyChannels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NO SECURE CHANNELS DETECTED"
                    android:textColor="#777777"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:padding="24dp"/>

            </LinearLayout>
        </ScrollView>

        </LinearLayout>
            
    </LinearLayout>

</LinearLayout>
