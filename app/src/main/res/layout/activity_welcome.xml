<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RAMcryptr"
        android:textColor="#00FFAA"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Secure Tactical Communication Layer"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnInitiate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="INITIATE COMMN"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#00FFAA"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnPatchIn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="PATCH IN"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#00CCFF"/>

</LinearLayout>
