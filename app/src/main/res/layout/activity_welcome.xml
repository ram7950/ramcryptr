<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#000000"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/welcomeContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RAMcryptr"
        android:textColor="#00FFAA"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Secure Tactical Communication Layer"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnInitiate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="INITIATE COMMN"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#00FFAA"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnPatchIn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="PATCH IN"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#00CCFF"/>

</LinearLayout>

    <!-- BACKGROUND VIDEO -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/bgVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.45"
        android:scaleX="1.8"
        android:scaleY="1.8"
        android:keepScreenOn="true"
        app:use_controller="false"
        app:resize_mode="zoom"/>

    <!-- MAIN VIDEO -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/introVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        app:use_controller="false"
        app:resize_mode="zoom"/>

</FrameLayout>
